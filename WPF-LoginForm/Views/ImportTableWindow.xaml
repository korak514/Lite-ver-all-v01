<Window x:Class="WPF_LoginForm.Views.ImportTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_LoginForm.Views"
        xmlns:viewModels="clr-namespace:WPF_LoginForm.ViewModels"
        xmlns:converters="clr-namespace:WPF_LoginForm.Converters"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:ImportTableViewModel, IsDesignTimeCreatable=False}"
        Title="{x:Static p:Resources.Str_ImportData}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MinWidth="450">

    <Window.Resources>
        <!-- CORRECTED: Reference the converter from the Converters namespace -->
        <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Str_ImportWizard}" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="{x:Static p:Resources.Str_ImportHint}" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,20"/>

        <!-- File Selection -->
        <GroupBox Grid.Row="2" Header="{x:Static p:Resources.Str_SelectSourceFile}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FilePath}" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <Button Grid.Column="1" Content="{x:Static p:Resources.Str_BrowseEllipsis}" Command="{Binding BrowseCommand}" Padding="15,5"/>
            </Grid>
        </GroupBox>

        <!-- Row 1: Advanced Options -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
            <Label Content="{x:Static p:Resources.Str_RowsToIgnore}" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding AvailableRowCounts}"
                      SelectedItem="{Binding RowsToIgnore, Mode=TwoWay}"
                      Margin="5,0,0,0"
                      HorizontalAlignment="Left"
                      Width="60"/>
        </StackPanel>

        <!-- Row 2: OK/Cancel Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="{x:Static p:Resources.Str_Cancel}" Click="CancelButton_Click" Width="100" Height="35" Background="Transparent" Foreground="#666" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,10,0"/>
            <Button Content="{x:Static p:Resources.Str_StartImport}" Width="150" Height="35" Background="#28A745" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="OkButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="IsEnabled" Value="False"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilePath, Converter={StaticResource IsNullOrEmptyConverter}}" Value="False">
                                <Setter Property="IsEnabled" Value="True"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="_Cancel" IsCancel="True" Width="75" Click="CancelButton_Click"/>
        </StackPanel>

    </Grid>

</Window>