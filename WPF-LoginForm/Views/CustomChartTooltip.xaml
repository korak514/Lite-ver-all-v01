<!-- Views/CustomChartTooltip.xaml -->
<UserControl x:Class="WPF_LoginForm.Views.CustomChartTooltip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AutoCollapseTextBlock" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#F2000025" BorderBrush="#50FFFFFF" BorderThickness="1" CornerRadius="6">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.6" ShadowDepth="4" />
        </Border.Effect>

        <ItemsControl ItemsSource="{Binding Data.Points}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1">
                        <Grid MinWidth="180">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- PART 1: HEADER -->
                            <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1" Margin="10,6">
                                <TextBlock Text="{Binding ChartPoint.Instance.TooltipHeader}"
                                           Style="{StaticResource AutoCollapseTextBlock}"
                                           Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                            </Border>

                            <!-- PART 2: LEFT SIDE -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,8,15,8">
                                <Ellipse Width="10" Height="10" Fill="{Binding Series.Fill}" Stroke="WhiteSmoke" StrokeThickness="1.5" Margin="0,0,8,0" VerticalAlignment="Top" />
                                <TextBlock Text="{Binding ChartPoint.Instance.TooltipLeft}"
                                           Style="{StaticResource AutoCollapseTextBlock}"
                                           Foreground="WhiteSmoke" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>

                            <!-- PART 3: RIGHT SIDE -->
                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="#30FFFFFF" BorderThickness="1,0,0,0" Margin="15,8,10,8">
                                <TextBlock Text="{Binding ChartPoint.Instance.TooltipRight}"
                                           Style="{StaticResource AutoCollapseTextBlock}"
                                           Foreground="White" FontWeight="Bold" FontSize="12"
                                           HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>