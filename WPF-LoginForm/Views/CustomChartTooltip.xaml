<!-- Views/CustomChartTooltip.xaml -->
<UserControl x:Class="WPF_LoginForm.Views.CustomChartTooltip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="AutoCollapseTextBlock" TargetType="TextBlock">
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#F2000025" BorderBrush="#50FFFFFF" BorderThickness="1" CornerRadius="6" Padding="4">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.6" ShadowDepth="4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. GLOBAL HEADER (e.g., May 2025) -->
            <Border Grid.Row="0" BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1" Margin="5,4,5,8">
                <TextBlock Text="{Binding GlobalHeader}"
                           Style="{StaticResource AutoCollapseTextBlock}"
                           Foreground="White" FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center" TextAlignment="Center" />
            </Border>

            <!-- 2. BODY (Shared Left + List of Rights) -->
            <Grid Grid.Row="1" Margin="5,0,5,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- SHARED LEFT COLUMN (e.g., Cam 191205) -->
                <Border Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" Padding="0,0,5,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SharedTooltipLeft}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SharedTooltipLeft}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SharedTooltipLeft}"
                               Foreground="WhiteSmoke" FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="150" />
                </Border>

                <!-- LIST OF SERIES -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Data.Points}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- SERIES DOT -->
                                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding Series.Fill}" 
                                         Stroke="WhiteSmoke" StrokeThickness="1" Margin="0,0,8,0" VerticalAlignment="Center" />

                                <!-- ITEM CONTENT -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <!-- Only show TooltipLeft if NOT shared globally -->
                                    <TextBlock Text="{Binding ChartPoint.Instance.TooltipLeft}" Margin="0,0,8,0"
                                               Foreground="WhiteSmoke" FontSize="11" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource AutoCollapseTextBlock}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.SharedTooltipLeft, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.SharedTooltipLeft, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                    <TextBlock Text="{Binding ChartPoint.Instance.TooltipRight}"
                                               Foreground="White" FontWeight="Bold" FontSize="12"
                                               VerticalAlignment="Center" TextAlignment="Left" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>