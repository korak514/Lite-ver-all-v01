<Window x:Class="WPF_LoginForm.Views.MonthlyErrorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WPF_LoginForm.Converters"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        Title="Monthly Validation" Height="760" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#09092B">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="Border" x:Key="CheckRowStyle">
            <Setter Property="Background" Value="#1A1A3A" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Grid.Row="0" Text="Monthly Data Validation" Foreground="#FFC047" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />

        <!-- CALENDAR -->
        <Border Grid.Row="1" Background="#1A1A3A" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding MonthYearText}" Foreground="#FFC047" FontSize="12" FontWeight="Bold" Margin="0,0,0,5" />

                <ItemsControl ItemsSource="{Binding DayHeaders}" Margin="0,0,0,2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="Gray" FontSize="9" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding CalendarDays}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="7" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="32" Height="32" Margin="1" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" CornerRadius="8,8,0,0" Margin="1"
                                        Background="{Binding LeftColor}" Opacity="0.7" />
                                <Border Grid.Row="1" CornerRadius="0,0,8,8" Margin="1"
                                        Background="{Binding RightColor}" Opacity="0.7" />
                                <Border Grid.RowSpan="2" Width="28" Height="28" CornerRadius="14" Margin="2"
                                        Background="{Binding BackgroundColor}" BorderThickness="0" />
                                <TextBlock Grid.RowSpan="2" Text="{Binding Day}" FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#666666" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsColored}" Value="True">
                                                    <Setter Property="Foreground" Value="White" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- CHECKS -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Checks}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CheckRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding CheckName}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                <TextBlock Text="{Binding Detail}" Foreground="Gray" FontSize="11" Margin="0,2,0,0" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="{Binding StatusColor}" CornerRadius="4" Padding="14,6" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="Bold" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- FOOTER -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding SummaryText}" Foreground="Gray" FontSize="12" VerticalAlignment="Center" Margin="0,0,15,0" />
            <Button Content="Close" Click="CloseButton_Click" Background="#333" Foreground="White" BorderThickness="0" Cursor="Hand" Padding="20,8" />
        </StackPanel>
    </Grid>
</Window>
