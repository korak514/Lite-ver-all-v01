<Window x:Class="WPF_LoginForm.Views.DailyTimelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:converters="clr-namespace:WPF_LoginForm.Converters"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        Title="{x:Static p:Resources.Str_DailyTimeline}" Height="740" Width="1350"
        WindowStartupLocation="CenterOwner"
        Background="#09092B"
        MinWidth="1100" MinHeight="600">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanConverter x:Key="BooleanInverter" />

        <!-- Clean Action Button Style (Prevents squished labels) -->
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Icon-Only Buttons -->
        <Style TargetType="Button" x:Key="IconButtonStyle" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style TargetType="TextBox" x:Key="EditBoxStyle">
            <Setter Property="Height" Value="30" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#10102A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#303050" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>

        <Style TargetType="TextBlock" x:Key="EditLabelStyle">
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Custom Day Toggle Button -->
        <Style x:Key="DayToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#80F39C12" />
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4,0,0,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#F1C40F" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Custom Night Toggle Button -->
        <Style x:Key="NightToggleStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="#80191970" />
            <Setter Property="Foreground" Value="LightGray" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0,4,4,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2980B9" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TOP HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ROW 1: Date & Main Actions -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Date Navigation & Display -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding PrevDayCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <fa:ImageAwesome Icon="ChevronLeft" Height="25" Foreground="Gray" Margin="0,0,10,0" />
                    </Button>

                    <Border Background="#181838" BorderBrush="#3498DB" BorderThickness="2" CornerRadius="8" Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                            <Grid>
                                <!-- Invisible DatePicker mapped to the icon -->
                                <DatePicker x:Name="HiddenDatePicker" SelectedDate="{Binding TargetDate, Mode=TwoWay}" Width="0" Height="0" Opacity="0" />
                                <Button Click="OpenDatePicker_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" ToolTip="Tarih Seç">
                                    <fa:ImageAwesome Icon="Calendar" Height="25" Foreground="#3498DB" VerticalAlignment="Center" />
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding FormattedDateNumber}" Foreground="White" FontSize="32" FontWeight="ExtraBold" VerticalAlignment="Center" />
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FormattedDateMonthYear}" Foreground="#FFC047" FontSize="14" FontWeight="Bold" />
                                <TextBlock Text="{Binding FormattedDay}" Foreground="LightGray" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding NextDayCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <fa:ImageAwesome Icon="ChevronRight" Height="25" Foreground="Gray" Margin="10,0,0,0" />
                    </Button>
                </StackPanel>

                <!-- FIX: Data Action Buttons (Responsive & Clean) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <Button Command="{Binding UndoCommand}" ToolTip="{x:Static p:Resources.Tip_UndoChanges}" Background="#7F8C8D" Margin="0,0,8,0" Style="{StaticResource IconButtonStyle}">
                        <fa:ImageAwesome Icon="Undo" Height="14" Foreground="White" />
                    </Button>

                    <Button Command="{Binding RefreshCommand}" ToolTip="{x:Static p:Resources.Tip_RefreshDB}" Background="#F39C12" Margin="0,0,15,0" Style="{StaticResource IconButtonStyle}">
                        <fa:ImageAwesome Icon="Refresh" Height="14" Foreground="White" />
                    </Button>

                    <Button Command="{Binding SaveToDatabaseCommand}" Background="#003399" Margin="0,0,15,0" Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Save" Height="13" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Kaydet" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ToggleFavoritesCommand}" Background="#9B59B6" Margin="0,0,8,0" Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Star" Height="13" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Favoriler" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding AddNewEventCommand}" Background="#27AE60" Margin="0,0,8,0" Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Plus" Height="13" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Yeni Ekle" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ToggleEditPanelCommand}" Background="#3498DB" Margin="0,0,15,0" Style="{StaticResource ActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Pencil" Height="13" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Düzenle" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="CloseButton_Click" Background="#E74C3C" Style="{StaticResource IconButtonStyle}">
                        <fa:ImageAwesome Icon="Times" Height="16" Foreground="White" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ROW 2: KPIs & View Controls -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- KPI CARDS -->
                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- KPI 1: Mola / Bakım -->
                        <Border Background="#1A1A3A" BorderBrush="#2ECC71" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Wrench" Height="10" Foreground="Gray" Margin="0,0,5,0" />
                                    <TextBlock Text="Mola / Bakım Kazanımı" Foreground="Gray" FontSize="10" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding AutoCalculatedMolaKazanimi, StringFormat={}{0}m}" Foreground="#2ECC71" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="{Binding RawMolaKazanimi, StringFormat={} DB: {0}m}" Foreground="DarkGray" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- KPI 2: Bypass -->
                        <Border Background="#1A1A3A" BorderBrush="#8E44AD" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Forward" Height="10" Foreground="Gray" Margin="0,0,5,0" />
                                    <TextBlock Text="Bypass Kazanımı" Foreground="Gray" FontSize="10" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding ManualBypassKazanimi, StringFormat={}{0}m}" Foreground="#8E44AD" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="{Binding RawBypassKazanimi, StringFormat={} DB: {0}m}" Foreground="DarkGray" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- KPI 3: Fiili Çalışılan Süre -->
                        <Border Background="#1A1A3A" BorderBrush="#3498DB" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Cog" Height="10" Foreground="Gray" Margin="0,0,5,0" />
                                    <TextBlock Text="Fiili Süre" Foreground="Gray" FontSize="10" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding AutoFiiliSureFormatted}" Foreground="#3498DB" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="{Binding RawFiiliSureFormatted, StringFormat={} DB: {0}}" Foreground="DarkGray" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- KPI 4: Yanlış zaman Verisi -->
                        <Border Background="#1A1A3A" BorderBrush="#E74C3C" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="ClockOutline" Height="10" Foreground="Gray" Margin="0,0,5,0" />
                                    <TextBlock Text="Yanlış Zaman Verisi" Foreground="Gray" FontSize="10" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding WrongTimeCount}" Foreground="#E74C3C" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="Adet" Foreground="DarkGray" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- KPI 5: Bozuk Veri -->
                        <Border Background="#1A1A3A" BorderBrush="#C0392B" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,10,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Ban" Height="10" Foreground="Gray" Margin="0,0,5,0" />
                                    <TextBlock Text="Bozuk Veri" Foreground="Gray" FontSize="10" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding CorruptedDataCount}" Foreground="#C0392B" FontSize="16" FontWeight="Bold" />
                                    <TextBlock Text="Adet" Foreground="DarkGray" FontSize="11" VerticalAlignment="Bottom" Margin="5,0,0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- View Controls (Zoom, Shift, Ruler) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- FIX: Crash Area (Removed missing x:Static refs, fixed Icon enum) -->
                    <Border Background="#181838" CornerRadius="4" Margin="0,0,10,0" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Database" Height="14" Foreground="Gray" Margin="0,0,5,0" />
                            <TextBlock Text="Referans Tablo:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <ComboBox ItemsSource="{Binding RulerTables}" SelectedItem="{Binding SelectedRulerTable, Mode=TwoWay}" Width="110" Height="22" VerticalContentAlignment="Center" Background="#202020" Foreground="DarkBlue" BorderThickness="0" />
                        </StackPanel>
                    </Border>

                    <!-- FIX: SearchPlus -> Search & Str_Zoom crash resolution -->
                    <Border Background="#181838" CornerRadius="4" Margin="0,0,10,0" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Search" Height="14" Foreground="Gray" Margin="0,0,5,0" />
                            <TextBlock Text="Yakınlaştır:" Foreground="Gray" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <Slider Minimum="2" Maximum="12" Value="{Binding TimeWindowHours, Mode=TwoWay}"
                                    Width="100" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                            <TextBlock Text="{Binding TimeWindowHours, StringFormat={}{0}h}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0" Width="25" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Gündüz" IsChecked="{Binding IsNightShift, Converter={StaticResource BooleanInverter}}" Style="{StaticResource DayToggleStyle}" />
                        <RadioButton Content="Gece" IsChecked="{Binding IsNightShift}" Style="{StaticResource NightToggleStyle}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- FAVORITES BAR -->
        <Border Grid.Row="1" Background="#1A1A3A" CornerRadius="6" Padding="10" Margin="0,0,0,15"
                Visibility="{Binding IsFavoritesVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Favoriler (Eklenecek veriyi sürükleyip bırakabilirsiniz)" Foreground="#FFC047" FontSize="12" FontWeight="Bold" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding FavoriteEvents}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding ColorHex}" CornerRadius="15" Margin="0,0,10,5" Padding="10,5" Cursor="Hand"
                                    PreviewMouseLeftButtonDown="FavoriteBorder_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="FavoriteBorder_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="FavoriteBorder_PreviewMouseLeftButtonUp">

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />

                                    <Button Content="✕"
                                            Command="{Binding DataContext.RemoveFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="#80FFFFFF" BorderThickness="0"
                                            Margin="5,0,0,0" Padding="3,0" Cursor="Hand" ToolTip="Kaldır">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- MAIN LAYOUT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: TV GUIDE TIMELINE -->
            <Border Grid.Column="0" Background="#181838" CornerRadius="8" x:Name="TimelineViewport" SizeChanged="TimelineViewport_SizeChanged" ClipToBounds="True">
                <ScrollViewer x:Name="TimelineScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              PreviewMouseLeftButtonDown="ScrollViewer_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="ScrollViewer_PreviewMouseMove"
                              PreviewMouseLeftButtonUp="ScrollViewer_PreviewMouseLeftButtonUp">

                    <Canvas x:Name="MainCanvas" Width="{Binding CalculatedCanvasWidth}" Height="520" Background="Transparent"
                            AllowDrop="True" DragOver="TimelineCanvas_DragOver" Drop="TimelineCanvas_Drop"
                            MouseLeftButtonDown="TimelineCanvas_MouseLeftButtonDown">

                        <!-- RULER HIGHLIGHT BAND -->
                        <Border Canvas.Top="0" Canvas.Left="0" Width="{Binding CalculatedCanvasWidth}" Height="30" Background="#15FFFFFF" />
                        <TextBlock Text="REF" Foreground="#80FFFFFF" FontSize="10" FontWeight="Bold" Canvas.Left="5" Canvas.Top="8" />

                        <!-- HORIZONTAL LANE LINES -->
                        <Line X1="0" Y1="30" X2="{Binding CalculatedCanvasWidth}" Y2="30" Stroke="#40FFFFFF" StrokeThickness="2" />
                        <Line X1="0" Y1="110" X2="{Binding CalculatedCanvasWidth}" Y2="110" Stroke="#20FFFFFF" StrokeThickness="1" />
                        <Line X1="0" Y1="190" X2="{Binding CalculatedCanvasWidth}" Y2="190" Stroke="#20FFFFFF" StrokeThickness="1" />
                        <Line X1="0" Y1="270" X2="{Binding CalculatedCanvasWidth}" Y2="270" Stroke="#20FFFFFF" StrokeThickness="1" />
                        <Line X1="0" Y1="350" X2="{Binding CalculatedCanvasWidth}" Y2="350" Stroke="#20FFFFFF" StrokeThickness="1" />
                        <Line X1="0" Y1="430" X2="{Binding CalculatedCanvasWidth}" Y2="430" Stroke="#20FFFFFF" StrokeThickness="1" />
                        <Line X1="0" Y1="510" X2="{Binding CalculatedCanvasWidth}" Y2="510" Stroke="#40FFFFFF" StrokeThickness="2" />

                        <!-- VERTICAL HOUR LINES & LABELS -->
                        <ItemsControl ItemsSource="{Binding HourMarkers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas>
                                        <Line X1="0" Y1="0" X2="0" Y2="510" Stroke="#30FFFFFF" StrokeThickness="1" />
                                        <TextBlock Text="{Binding Text}" Foreground="LightGray" FontWeight="Bold" Canvas.Top="32" Canvas.Left="-15" Width="35" TextAlignment="Center" />
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding PixelX}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>

                        <!-- REFERENCE BLOCKS (MASTER RULER) -->
                        <ItemsControl ItemsSource="{Binding ReferenceBlocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding PixelWidth}" Height="20"
                                            Background="{Binding BlockColor}"
                                            CornerRadius="2"
                                            ToolTip="{Binding DisplayText}"
                                            BorderBrush="#80FFFFFF" BorderThickness="1">
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding PixelX}" />
                                    <Setter Property="Canvas.Top" Value="{Binding PixelY}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>

                        <!-- EVENT BLOCKS -->
                        <ItemsControl ItemsSource="{Binding TimelineBlocks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding PixelWidth}" Height="70"
                                            Background="{Binding BlockColor}"
                                            CornerRadius="4" Cursor="Hand"
                                            ToolTip="{Binding DisplayText}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.BlockClickCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>

                                        <TextBlock Text="{Binding DisplayText}"
                                                   Foreground="White"
                                                   FontSize="{Binding TextFontSize}"
                                                   Visibility="{Binding IsTextVisible, Converter={StaticResource BoolToVis}}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"
                                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding PixelX}" />
                                    <Setter Property="Canvas.Top" Value="{Binding PixelY}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                    </Canvas>
                </ScrollViewer>
            </Border>

            <!-- Margin column to separate timeline and edit panel -->
            <Border Grid.Column="1" Width="15" Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVis}}" />

            <!-- RIGHT: EDIT PANEL (Fixed Width) -->
            <Border Grid.Column="2" Width="380" Background="#1E1E3F" CornerRadius="8" Padding="20"
                    Visibility="{Binding IsEditPanelVisible, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Olay Detayları" Foreground="#FFC047" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <TextBlock Text="Başlangıç Saati:" Style="{StaticResource EditLabelStyle}" />
                            <TextBox Text="{Binding EditStartTime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditBoxStyle}" />

                            <!-- End Time / Duration Toggle -->
                            <CheckBox Content="Bitiş Saatini Belirt" IsChecked="{Binding UseEndTimeMode}" Foreground="LightGray" Margin="0,0,0,10" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                    <TextBlock Text="Süre (Dk):" Style="{StaticResource EditLabelStyle}" />
                                    <TextBox Text="{Binding EditDuration, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding UseEndTimeMode, Converter={StaticResource BooleanInverter}}"
                                             Style="{StaticResource EditBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                    <TextBlock Text="Bitiş Saati:" Style="{StaticResource EditLabelStyle}" />
                                    <TextBox Text="{Binding EditEndTime, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding UseEndTimeMode}"
                                             Style="{StaticResource EditBoxStyle}" />
                                </StackPanel>
                            </Grid>

                            <!-- UNIFIED MACHINE CODE SELECTOR -->
                            <TextBlock Text="Makine Kodu:" Style="{StaticResource EditLabelStyle}" />

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableMachineCodes}"
                                          Text="{Binding SelectedBlock.OriginalEvent.MachineCode, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          Height="30" VerticalContentAlignment="Center" />

                                <!-- FIX: Gear -> Cog enum crash resolution -->
                                <Button Grid.Column="1" Command="{Binding ManageMachineCodesCommand}" Width="30" Height="30" Margin="5,0,0,0" Background="#333" BorderThickness="0" Cursor="Hand" ToolTip="Makine Kodlarını Düzenle">
                                    <fa:ImageAwesome Icon="Cog" Height="14" Foreground="White" />
                                </Button>
                            </Grid>

                            <TextBlock Text="Açıklama:" Style="{StaticResource EditLabelStyle}" />
                            <TextBox Text="{Binding SelectedBlock.OriginalEvent.ErrorDescription, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource EditBoxStyle}" />

                            <!-- BYPASS FLAG -->
                            <CheckBox Content="Bypass olarak işaretle"
                                      IsChecked="{Binding SelectedBlock.IsBypass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#FFC047" FontWeight="SemiBold" Margin="0,5,0,15" />

                            <Button Command="{Binding SaveAsFavoriteCommand}" Background="#8E44AD" Margin="0,5,0,15" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Left">
                                <TextBlock Text="Favori Olarak Kaydet" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Command="{Binding DeleteEventCommand}" Background="#D14545" Margin="0,0,10,0" Style="{StaticResource ActionButtonStyle}">
                            <TextBlock Text="Sil" FontSize="12" />
                        </Button>
                        <Button Command="{Binding ApplyToTimelineCommand}" Background="#0078D7" Style="{StaticResource ActionButtonStyle}">
                            <TextBlock Text="Çizelgeye Ekle" FontSize="12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>