<Window x:Class="WPF_LoginForm.Views.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="{Binding WindowTitle}" 
        SizeToContent="Height" 
        Width="420"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize" 
        Background="#F8F9FA">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   x:Name="lblMessage" 
                   Text="{Binding PromptText}" 
                   TextWrapping="Wrap" 
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" 
                   Foreground="#333"/>

        <TextBox Grid.Row="1" 
                 x:Name="txtInput" 
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" 
                 Height="32"
                 VerticalContentAlignment="Center" 
                 Padding="8,0"
                 FontSize="14"
                 BorderBrush="#CCC"/>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            
            <Button IsCancel="True" 
                    Click="Cancel_Click" 
                    Width="100" 
                    Height="34"
                    Margin="0,0,10,0"
                    Background="#E74C3C"
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <fa:ImageAwesome Icon="Times" Width="12" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="{x:Static p:Resources.Str_Cancel}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button IsDefault="True" 
                    Click="Ok_Click" 
                    Width="100" 
                    Height="34"
                    Background="#2ECC71" 
                    Foreground="White">
                <StackPanel Orientation="Horizontal">
                    <fa:ImageAwesome Icon="Check" Width="12" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="{x:Static p:Resources.Str_OK}" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>