<Window x:Class="WPF_LoginForm.Views.InputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        Title="{Binding WindowTitle}" Height="150" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F8F9FA">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="lblMessage" Text="{Binding PromptText}" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#333"/>
        <TextBox Grid.Row="1" x:Name="txtInput" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="5"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="{x:Static p:Resources.Str_Cancel}" IsCancel="True" Click="Cancel_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="{x:Static p:Resources.Str_OK}" IsDefault="True" Click="Ok_Click" Width="80" Background="#0078D7" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>