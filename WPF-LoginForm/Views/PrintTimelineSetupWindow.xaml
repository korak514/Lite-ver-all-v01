<Window x:Class="WPF_LoginForm.Views.PrintTimelineSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:WPF_LoginForm.ViewModels"
        xmlns:converters="clr-namespace:WPF_LoginForm.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Printable 17-Day Timeline Report" Height="760" Width="1300"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanConverter x:Key="InverseBool" />
        <converters:StringToBrushConverter x:Key="StringToBrush" />
        <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />

        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#333" />
            <Setter Property="Margin" Value="0,10,0,2" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditingBlock}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="Report Configuration" FontSize="18" FontWeight="Bold" Foreground="#0056B3" Margin="0,0,0,15" />

                        <TextBlock Text="Primary Database Table" Style="{StaticResource HeaderStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableTables}" SelectedItem="{Binding SelectedTable}" Height="25" Margin="0,0,0,10" />

                        <TextBlock Text="Merge Extra Data from Excel" Style="{StaticResource HeaderStyle}" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ExcelFilePath}" IsReadOnly="True" Height="25" VerticalContentAlignment="Center" />
                            <Button Grid.Column="1" Content="..." Command="{Binding BrowseExcelCommand}" Width="25" Margin="5,0,0,0" ToolTip="Select Excel" />
                            <Button Grid.Column="2" Content="X" Command="{Binding ClearExcelCommand}" Width="25" Margin="5,0,0,0" Foreground="Red" ToolTip="Clear Excel" />
                        </Grid>

                        <TextBlock Text="Date Range (17 Days max for A4)" Style="{StaticResource HeaderStyle}" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" SelectedDate="{Binding StartDate}" />
                            <TextBlock Grid.Column="1" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <DatePicker Grid.Column="2" SelectedDate="{Binding EndDate}" />
                        </Grid>

                        <TextBlock Text="Extra Information Columns" Style="{StaticResource HeaderStyle}" />
                        <TextBlock Text="Column 1:" Foreground="Gray" FontSize="11" Margin="0,5,0,0" />
                        <ComboBox ItemsSource="{Binding AvailableExtraOptions}" SelectedItem="{Binding ExtraCol1Selection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,5" />
                        <TextBlock Text="Column 2:" Foreground="Gray" FontSize="11" />
                        <ComboBox ItemsSource="{Binding AvailableExtraOptions}" SelectedItem="{Binding ExtraCol2Selection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" />

                        <Expander Header="Visual &amp; Global Colors" IsExpanded="False" Background="#F8F9FA" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,5">
                            <StackPanel Margin="0,10,0,0">
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Running:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding RunningColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Errors (Primary):" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ErrorColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Errors (Overlap):" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ErrorColor2, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Normal Breaks:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding BreakColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Facility Stopped:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding FacilityStopColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Text inside Events:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding InnerLabelColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander Header="MA-00 Specific Categories" IsExpanded="False" Background="#E8F4F8" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,10">
                            <StackPanel Margin="0,10,0,0">
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="1. Genel Temizlik:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Genel, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="2. Çay Molası:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Cay, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="3. Yemek Molası:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Yemek, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="4. Diğer MA-00:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Other, Mode=TwoWay}" Height="24" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <TextBlock Text="Timeline Row Height" Style="{StaticResource HeaderStyle}" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Slider Minimum="8" Maximum="32" Value="{Binding RowHeight, Mode=TwoWay}" Width="160" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                            <TextBlock Text="{Binding RowHeight}" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="Configuration Toggles" Style="{StaticResource HeaderStyle}" />
                        <CheckBox Content="Display DB numeric values in Hours" IsChecked="{Binding ShowValuesInHours, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                        <CheckBox Content="Show Machine ID &amp; Texts on Errors" IsChecked="{Binding ShowMajorErrorLabels, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                        <CheckBox Content="Detailed View for Overlaps (ex: 21, 02)" IsChecked="{Binding DetailedOverlapView, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                        <CheckBox Content="Hide 'Genel Temizlik' Labels (MA-00)" IsChecked="{Binding HideGenelTemizlik, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                        <CheckBox Content="Show Machine Legend Top-Right" IsChecked="{Binding ShowMachineLegend, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />

                        <ProgressBar IsIndeterminate="True" Height="5" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- SPECIFIC BLOCK EDITOR PANEL -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" Background="#FFFDF5">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditingBlock}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <Button Content="⬅ Back to Configuration" Command="{Binding CancelBlockEditCommand}" Background="Transparent" Foreground="#0056B3" BorderThickness="0" HorizontalAlignment="Left" Margin="0,0,0,10" FontWeight="Bold" Cursor="Hand" />

                        <TextBlock Text="Manual Block Editor" FontSize="18" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,5" />
                        <TextBlock Text="Edit exactly what prints for this block. Changes are lost if you click 'Generate Preview' again." FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15" />

                        <TextBlock Text="Block Time Info" Style="{StaticResource HeaderStyle}" Foreground="#E67E22" />
                        <TextBlock Text="{Binding EditBlockTimeData}" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,15" />

                        <TextBlock Text="Forced Category Assignment" Style="{StaticResource HeaderStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableBlockCategories}" SelectedItem="{Binding SelectedBlockCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" />

                        <TextBlock Text="Block Fill Color (Auto-set by Category)" Style="{StaticResource HeaderStyle}" />
                        <xctk:ColorPicker SelectedColor="{Binding EditBlockColor, Mode=TwoWay}" Height="25" Margin="0,0,0,15" />

                        <TextBlock Text="Inner Block Text (Label)" Style="{StaticResource HeaderStyle}" />
                        <TextBox Text="{Binding EditBlockLabel, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center" />

                        <TextBlock Text="Machine Code (for footnotes)" Style="{StaticResource HeaderStyle}" />
                        <TextBox Text="{Binding EditBlockMachine, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center" ToolTip="Typing '00' automatically swaps the Forced Category list." />

                        <Border Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,5,0,15">
                            <StackPanel>
                                <CheckBox Content="Force into Footnotes" IsChecked="{Binding EditBlockIsFootnote}" FontWeight="Bold" Margin="0,0,0,10" />
                                <TextBlock Text="Footnote Description:" FontSize="11" Foreground="#555" Margin="0,0,0,5" />
                                <TextBox Text="{Binding EditBlockDesc, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center" IsEnabled="{Binding EditBlockIsFootnote}" />
                            </StackPanel>
                        </Border>

                        <Button Content="✓ Apply Overrides" Command="{Binding ApplyBlockEditCommand}" Height="35" Background="#28A745" Foreground="White" FontWeight="Bold" Margin="0,15,0,10" />
                        <Button Content="✗ Cancel &amp; Go Back" Command="{Binding CancelBlockEditCommand}" Height="30" Background="#E74C3C" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Margin="0,15,0,0">
                    <Button Content="Generate Preview (Saves Settings)" Command="{Binding GeneratePreviewCommand}" Height="35" Background="#0056B3" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" />
                    <Button Content="🖨 Print to A4 Landscape" Command="{Binding PrintCommand}" Height="35" Background="#2ECC71" Foreground="White" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: A4 PREVIEW WITH ZOOM -->
        <Grid Grid.Column="1" Background="#E0E0E0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">

                <!-- Zoom Wrapper Grid -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}" />
                    </Grid.LayoutTransform>

                    <Border x:Name="PrintArea" Width="1123" Height="794" Background="White" Padding="30">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="3" />
                        </Border.Effect>

                        <Grid>
                            <!-- UPDATED ROW DEFINITIONS FOR GAP FIX -->
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <!-- 0: Header -->
                                <RowDefinition Height="Auto" />
                                <!-- 1: Top Ruler -->
                                <RowDefinition Height="Auto" />
                                <!-- 2: Data Rows (Changed from * to Auto to snap to top) -->
                                <RowDefinition Height="Auto" />
                                <!-- 3: Bottom Ruler -->
                                <RowDefinition Height="Auto" />
                                <!-- 4: Footnotes -->
                                <RowDefinition Height="*" />
                                <!-- 5: Empty space to consume the rest of A4 -->
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ReportConfig.ReportTitle}" FontSize="24" FontWeight="Bold" Foreground="#333" />
                                    <TextBlock Text="{Binding ReportConfig.DateRangeText}" FontSize="14" Foreground="#666" Margin="0,2,0,0" />

                                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,15,0,0" MaxWidth="850">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.RunningColor, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendRunning}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.BreakColor, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendBreak}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.ColorMa00Genel, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendMa00Genel}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.ColorMa00Cay, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendMa00Cay}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.ColorMa00Yemek, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendMa00Yemek}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.ColorMa00Other, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendMa00Other}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.ErrorColor, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendError}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.ErrorColor2, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendError2}" FontSize="11" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <Border Width="12" Height="12" Background="{Binding ReportConfig.FacilityStopColor, Converter={StaticResource StringToBrush}}" BorderBrush="Black" BorderThickness="1" Margin="0,0,5,0" />
                                            <TextBlock Text="{Binding ReportConfig.LegendFacilityStop}" FontSize="11" />
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>

                                <Border Grid.Column="2" Visibility="{Binding ReportConfig.ShowMachineLegend, Converter={StaticResource BoolToVis}}" BorderBrush="Black" BorderThickness="1" Background="#FAFAFA" Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                    <ItemsControl ItemsSource="{Binding ReportConfig.LegendItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="2" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="20" />
                                                        <ColumnDefinition Width="Auto" MinWidth="90" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Code}" FontSize="8" FontWeight="Bold" Foreground="#444" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="8" Foreground="#333" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1" Background="#F5F5F5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding ReportConfig.HeaderDate}" FontWeight="Bold" FontSize="11" Padding="5" />
                                <TextBlock Grid.Column="1" Text="{Binding ReportConfig.HeaderShift}" FontWeight="Bold" FontSize="11" Padding="5" HorizontalAlignment="Center" />
                                <Border Grid.Column="2" Width="90" Visibility="{Binding ReportConfig.ShowExtra1, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ReportConfig.ExtraTitle1}" FontWeight="Bold" FontSize="11" Padding="5" TextAlignment="Right" />
                                </Border>
                                <Border Grid.Column="3" Width="90" Visibility="{Binding ReportConfig.ShowExtra2, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ReportConfig.ExtraTitle2}" FontWeight="Bold" FontSize="11" Padding="5" TextAlignment="Right" />
                                </Border>

                                <Canvas Grid.Column="4" Width="{Binding ReportConfig.TimelineWidth}" Height="20" Margin="15,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReportConfig.AxisTicks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TopLabel}" FontSize="9" Foreground="#555" Width="40" TextAlignment="Center" Margin="0,5,0,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding TextPixelLeft}" />
                                                <Setter Property="Canvas.Top" Value="0" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>

                            <!-- Data Rows Grid.Row="2" -->
                            <ItemsControl Grid.Row="2" ItemsSource="{Binding ReportRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Margin="0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlternateBackground}" Value="True">
                                                            <Setter Property="Background" Value="#F2F4F7" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50" />
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding DisplayDate}" FontSize="{Binding DataContext.ReportConfig.TextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Padding="5,0" VerticalAlignment="Center" Visibility="{Binding ShowDate, Converter={StaticResource BoolToVis}}" />
                                                <TextBlock Grid.Column="1" Text="{Binding DisplayShift}" FontSize="{Binding DataContext.ReportConfig.SymbolFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Padding="5,0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Border Grid.Column="2" Width="90" Visibility="{Binding DataContext.ReportConfig.ShowExtra1, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding ExtraValue1}" FontSize="{Binding DataContext.ReportConfig.TextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Padding="5,0" TextAlignment="Right" VerticalAlignment="Center" />
                                                </Border>
                                                <Border Grid.Column="3" Width="90" Visibility="{Binding DataContext.ReportConfig.ShowExtra2, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding ExtraValue2}" FontSize="{Binding DataContext.ReportConfig.TextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Padding="5,0" TextAlignment="Right" VerticalAlignment="Center" />
                                                </Border>

                                                <Canvas Grid.Column="4" Width="{Binding DataContext.ReportConfig.TimelineWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding DataContext.ReportConfig.RowHeight, RelativeSource={RelativeSource AncestorType=Window}}" Margin="15,2,0,2" HorizontalAlignment="Left">

                                                    <ItemsControl ItemsSource="{Binding Blocks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <!-- ADDED TOOLTIP BINDING HERE -->
                                                                <Border Width="{Binding PixelWidth}" Height="{Binding DataContext.ReportConfig.RowHeight, RelativeSource={RelativeSource AncestorType=Window}}" Background="{x:Null}" Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                                                                    <Border.ToolTip>
                                                                        <ToolTip Background="#FDFDFD" BorderBrush="#CCC">
                                                                            <TextBlock>
                                                                                <Run Text="{Binding DisplayStartTime}" FontWeight="Bold" Foreground="#333" />
                                                                                <Run Text=" - " FontWeight="Bold" Foreground="#333" />
                                                                                <Run Text="{Binding DisplayEndTime}" FontWeight="Bold" Foreground="#333" />
                                                                                <LineBreak />
                                                                                <Run Text="{Binding OriginalDescription}" Foreground="#555" />
                                                                            </TextBlock>
                                                                        </ToolTip>
                                                                    </Border.ToolTip>
                                                                    <Border.RenderTransform>
                                                                        <ScaleTransform ScaleY="{Binding HeightMultiplier}" />
                                                                    </Border.RenderTransform>
                                                                    <Border.InputBindings>
                                                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectBlockCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                    </Border.InputBindings>
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="BorderThickness" Value="0" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                                    <Setter Property="BorderBrush" Value="Black" />
                                                                                    <Setter Property="Margin" Value="0,-1,0,-1" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>

                                                                    <Rectangle Fill="{Binding ColorHex, Converter={StaticResource StringToBrush}}" StrokeThickness="0" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding PixelLeft}" />
                                                                <Setter Property="Canvas.Top" Value="0" />
                                                                <Setter Property="Panel.ZIndex" Value="0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Panel.ZIndex" Value="99" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding DataContext.ReportConfig.AxisTicks, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Line X1="0" Y1="0" X2="0" Y2="{Binding RowHeight}" Stroke="#40000000" StrokeThickness="1" IsHitTestVisible="False" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding PixelLeft}" />
                                                                <Setter Property="Canvas.Top" Value="0" />
                                                                <Setter Property="Panel.ZIndex" Value="5" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding Blocks}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Label}" IsHitTestVisible="False" Foreground="{Binding DataContext.ReportConfig.InnerLabelColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToBrush}}" FontWeight="Bold" Height="{Binding DataContext.ReportConfig.RowHeight, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="{Binding DataContext.ReportConfig.InnerLabelFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Width="{Binding PixelWidth}" TextAlignment="Center" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Effect>
                                                                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.8" />
                                                                    </TextBlock.Effect>
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <MultiDataTrigger>
                                                                                    <MultiDataTrigger.Conditions>
                                                                                        <Condition Binding="{Binding DataContext.ReportConfig.ShowMajorErrorLabels, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                                                        <Condition Binding="{Binding Label, Converter={StaticResource IsNullOrEmptyConverter}}" Value="False" />
                                                                                    </MultiDataTrigger.Conditions>
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </MultiDataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding PixelLeft}" />
                                                                <Setter Property="Canvas.Top" Value="{Binding TopOffset}" />
                                                                <Setter Property="Panel.ZIndex" Value="10" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                    </ItemsControl>
                                                </Canvas>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Grid.Row="3" Background="#F5F5F5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="2" Width="90" Visibility="{Binding ReportConfig.ShowExtra1, Converter={StaticResource BoolToVis}}" />
                                <Border Grid.Column="3" Width="90" Visibility="{Binding ReportConfig.ShowExtra2, Converter={StaticResource BoolToVis}}" />

                                <Canvas Grid.Column="4" Width="{Binding ReportConfig.TimelineWidth}" Height="20" Margin="15,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReportConfig.AxisTicks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BottomLabel}" FontSize="9" Foreground="#555" Width="40" TextAlignment="Center" Margin="0,2,0,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding TextPixelLeft}" />
                                                <Setter Property="Canvas.Top" Value="0" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,15,0,0">
                                <ItemsControl ItemsSource="{Binding ReportConfig.Footnotes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="1" CornerRadius="2" Padding="4,2" Margin="0,0,10,5">
                                                <TextBlock Text="{Binding}" FontSize="10" Foreground="#444" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#AA000000" CornerRadius="5" Padding="10,5" Margin="20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Zoom:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" />
                    <Slider Minimum="0.5" Maximum="3.0" Value="{Binding ZoomScale}" Width="120" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.1" ToolTip="Adjust Zoom Level" />
                    <TextBlock Text="{Binding ZoomScale, StringFormat={}{0:P0}}" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Width="40" TextAlignment="Right" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>