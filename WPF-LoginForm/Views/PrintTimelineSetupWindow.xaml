<Window x:Class="WPF_LoginForm.Views.PrintTimelineSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:WPF_LoginForm.ViewModels"
        xmlns:converters="clr-namespace:WPF_LoginForm.Converters"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.Str_PrintableTimelineReport}" Height="760" Width="1300"
        WindowStartupLocation="CenterOwner" Background="#F0F2F5">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanConverter x:Key="InverseBool" />
        <converters:StringToBrushConverter x:Key="StringToBrush" />
        <converters:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />

        <Style TargetType="TextBlock" x:Key="HeaderStyle">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#333" />
            <Setter Property="Margin" Value="0,10,0,2" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- MAIN CONFIGURATION PANEL -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditingBlock}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="{x:Static p:Resources.Str_ReportConfiguration}" FontSize="18" FontWeight="Bold" Foreground="#0056B3" Margin="0,0,0,15" />

                        <TextBlock Text="{x:Static p:Resources.Str_PrimaryDatabaseTable}" Style="{StaticResource HeaderStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableTables}" SelectedItem="{Binding SelectedTable}" Height="25" Margin="0,0,0,10" />

                        <TextBlock Text="{x:Static p:Resources.Str_DateRangeAuto}" Style="{StaticResource HeaderStyle}" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <DatePicker Grid.Column="0" SelectedDate="{Binding StartDate}" />
                            <TextBlock Grid.Column="1" Text="-" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <DatePicker Grid.Column="2" SelectedDate="{Binding EndDate}" />
                        </Grid>

                        <Expander Header="Visual &amp; Global Colors" IsExpanded="False" Background="#F8F9FA" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,5">
                            <StackPanel Margin="0,10,0,0">
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Running:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding RunningColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Errors (Primary):" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ErrorColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Errors (Overlap):" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ErrorColor2, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Bypass (Çalışıyor):" VerticalAlignment="Center" FontWeight="Bold" Foreground="#666" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding BypassColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Facility Stopped:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding FacilityStopColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="115" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Text inside Events:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding InnerLabelColor, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <TextBlock Text="Default Text inside Events Size:" FontSize="11" Foreground="#555" Margin="0,10,0,2" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="4" Maximum="14" Value="{Binding InnerLabelFontSize, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.5" />
                                    <TextBlock Text="{Binding InnerLabelFontSize, StringFormat={}{0:F1}}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander Header="MA-00 Specific Categories" IsExpanded="False" Background="#E8F4F8" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,10">
                            <StackPanel Margin="0,10,0,0">
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="1. Genel Temizlik:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Genel, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="2. Çay Molası:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Cay, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="3. Yemek Molası:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Yemek, Mode=TwoWay}" Height="24" />
                                </Grid>
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="105" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="4. Diğer MA-00:" VerticalAlignment="Center" />
                                    <xctk:ColorPicker Grid.Column="1" SelectedColor="{Binding ColorMa00Other, Mode=TwoWay}" Height="24" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Default Layers &amp; Text Rules" IsExpanded="False" Background="#FFF5E6" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,10">
                            <StackPanel Margin="0,5,0,0">
                                <TextBlock Text="Higher layers draw on top of lower layers. Maximum limit is 100." TextWrapping="Wrap" FontSize="10" Foreground="#555" Margin="0,0,0,10" />

                                <TextBlock Text="Running (Canvas) Layer:" FontSize="11" Foreground="#555" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="1" Maximum="100" Value="{Binding LayerRunning, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding LayerRunning}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Bypass Layer:" FontSize="11" Foreground="#555" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="1" Maximum="100" Value="{Binding LayerBypass, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding LayerBypass}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Breaks &amp; Cleaning Layer:" FontSize="11" Foreground="#555" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="1" Maximum="100" Value="{Binding LayerBreaks, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding LayerBreaks}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Errors Layer (Base):" FontSize="11" Foreground="#555" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Slider Minimum="1" Maximum="100" Value="{Binding LayerErrors, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding LayerErrors}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,5,0,5" />
                                <TextBlock Text="Dynamic Height &amp; Text Rules:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5" />

                                <TextBlock Text="Overlap Cascade Step (% drop):" FontSize="11" Foreground="#555" ToolTip="How much smaller the next overlapping block gets." />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="0.05" Maximum="0.5" Value="{Binding OverlapCascadeStep, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.05" />
                                    <TextBlock Text="{Binding OverlapCascadeStep, StringFormat={}{0:P0}}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Min. Minutes for Label:" FontSize="11" Foreground="#555" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="30" Maximum="240" Value="{Binding MinLabelMinutes, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="10" />
                                    <TextBlock Text="{Binding MinLabelMinutes, StringFormat={}{0}m}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Min. Minutes for Footnote:" FontSize="11" Foreground="#555" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="5" Maximum="90" Value="{Binding MinFootnoteMinutes, Mode=TwoWay}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="5" />
                                    <TextBlock Text="{Binding MinFootnoteMinutes, StringFormat={}{0}m}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Advanced Layout Toggles &amp; Excel Data" IsExpanded="False" Background="#FFFDF5" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,10">
                            <StackPanel Margin="0,5,0,0">

                                <TextBlock Text="Excel Overrides (Col 1 &amp; 2)" Style="{StaticResource HeaderStyle}" Margin="0,0,0,2" />
                                <Grid Margin="0,0,0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ExcelFilePath}" IsReadOnly="True" Height="22" VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1" Content="..." Command="{Binding BrowseExcelCommand}" Width="22" Margin="5,0,0,0" />
                                    <Button Grid.Column="2" Content="X" Command="{Binding ClearExcelCommand}" Width="22" Margin="5,0,0,0" Foreground="Red" />
                                </Grid>
                                <ComboBox ItemsSource="{Binding AvailableExtraOptions}" SelectedItem="{Binding ExtraCol1Selection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="22" Margin="0,0,0,5" />
                                <ComboBox ItemsSource="{Binding AvailableExtraOptions}" SelectedItem="{Binding ExtraCol2Selection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="22" Margin="0,0,0,15" />

                                <TextBlock Text="Timeline Row Height" Style="{StaticResource HeaderStyle}" Margin="0,0,0,2" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Slider Minimum="8" Maximum="32" Value="{Binding RowHeight, Mode=TwoWay}" Width="160" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding RowHeight}" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold" />
                                </StackPanel>

                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,5,0,10" />
                                <TextBlock Text="{x:Static p:Resources.Str_BlockVisualStyles}" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5" />
                                <CheckBox Content="{x:Static p:Resources.Str_RoundedBlockCorners}" IsChecked="{Binding EnableSoftCorners, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                                <CheckBox Content="{x:Static p:Resources.Str_ForceSharpEdges}" IsChecked="{Binding DisableSoftCornersUnder5Min, Mode=TwoWay}" Margin="20,0,0,5" Foreground="#777" IsEnabled="{Binding EnableSoftCorners}" />
                                <CheckBox Content="{x:Static p:Resources.Str_ShowBlockOutlines}" IsChecked="{Binding EnableBlockBorders, Mode=TwoWay}" Margin="0,5,0,15" Foreground="#555" />

                                <Border BorderBrush="#DDD" BorderThickness="0,1,0,0" Margin="0,5,0,10" />
                                <CheckBox Content="{x:Static p:Resources.Str_DisplayDBHours}" IsChecked="{Binding ShowValuesInHours, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                                <CheckBox Content="{x:Static p:Resources.Str_ShowMachineIdTexts}" IsChecked="{Binding ShowMajorErrorLabels, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                                <CheckBox Content="{x:Static p:Resources.Str_HideGenelTemizlik}" IsChecked="{Binding HideGenelTemizlik, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                                <CheckBox Content="{x:Static p:Resources.Str_ShowMachineLegend}" IsChecked="{Binding ShowMachineLegend, Mode=TwoWay}" Margin="0,0,0,5" Foreground="#555" />
                                <CheckBox Content="{x:Static p:Resources.Str_ShowMonthSummary}" IsChecked="{Binding ShowMonthSummary, Mode=TwoWay}" Margin="0,0,0,15" Foreground="#1265B5" FontWeight="Bold" />
                            </StackPanel>
                        </Expander>

                        <ProgressBar IsIndeterminate="True" Height="5" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- LIVE BLOCK EDITOR PANEL -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0" Background="#FFFDF5">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditingBlock}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <Button Content="{x:Static p:Resources.Str_BackToConfiguration}" Command="{Binding CancelBlockEditCommand}" Background="Transparent" Foreground="#0056B3" BorderThickness="0" HorizontalAlignment="Left" Margin="0,0,0,10" FontWeight="Bold" Cursor="Hand" />

                        <TextBlock Text="{x:Static p:Resources.Str_LiveVisualEditor}" FontSize="18" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,5" />
                        <TextBlock Text="Edit exactly what prints for this block. Changes are automatically saved as overrides when you click Apply." FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,15" />

                        <TextBlock Text="{x:Static p:Resources.Str_BlockTimeInfo}" Style="{StaticResource HeaderStyle}" Foreground="#E67E22" />
                        <TextBlock Text="{Binding EditBlockTimeData}" FontSize="13" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,15" />

                        <TextBlock Text="{x:Static p:Resources.Str_ForcedCategoryAssignment}" Style="{StaticResource HeaderStyle}" />
                        <ComboBox ItemsSource="{Binding AvailableBlockCategories}" SelectedItem="{Binding SelectedBlockCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" />

                        <TextBlock Text="{x:Static p:Resources.Str_BlockFillColor}" Style="{StaticResource HeaderStyle}" />
                        <xctk:ColorPicker SelectedColor="{Binding EditBlockColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" />

                        <!-- TEXT & LABEL SECTION -->
                        <Expander Header="Text &amp; Label Configuration" IsExpanded="True" Background="#F0F8FF" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,15">
                            <StackPanel Margin="0,5,0,0">
                                <TextBlock Text="Inner Block Text (Label):" FontSize="11" Foreground="#555" />
                                <TextBox Text="{Binding EditBlockLabel, UpdateSourceTrigger=PropertyChanged}" Height="25" Margin="0,0,0,15" VerticalContentAlignment="Center" />

                                <TextBlock Text="Font Size Override:" FontSize="11" Foreground="#555" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Slider Minimum="3" Maximum="14" Value="{Binding EditBlockFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.5" />
                                    <TextBlock Text="{Binding EditBlockFontSize, StringFormat={}{0:F1}}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="X Offset (Left/Right Shift):" FontSize="11" Foreground="#555" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="-100" Maximum="100" Value="{Binding EditBlockLabelOffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding EditBlockLabelOffsetX, StringFormat={}{0}px}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Y Offset (Up/Down Shift):" FontSize="11" Foreground="#555" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="-30" Maximum="30" Value="{Binding EditBlockLabelOffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding EditBlockLabelOffsetY, StringFormat={}{0}px}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- SHAPE LAYER SECTION -->
                        <Expander Header="Advanced Layout &amp; Layering" IsExpanded="True" Background="#FAFAFA" BorderBrush="#CCC" BorderThickness="1" Padding="5" Margin="0,0,0,15">
                            <StackPanel Margin="0,5,0,0">
                                <TextBlock Text="Layer Z-Index (1 to 100):" FontSize="11" Foreground="#555" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="1" Maximum="100" Value="{Binding EditBlockZIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding EditBlockZIndex}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Height Scale (1.0 = Full Row):" FontSize="11" Foreground="#555" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="0.1" Maximum="1.0" Value="{Binding EditBlockHeightMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.05" />
                                    <TextBlock Text="{Binding EditBlockHeightMultiplier, StringFormat={}{0:F2}}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Push Down Offset (Pixels):" FontSize="11" Foreground="#555" Margin="0,5,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider Minimum="0" Maximum="32" Value="{Binding EditBlockTopOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" />
                                    <TextBlock Text="{Binding EditBlockTopOffset}" Margin="10,0,0,0" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Border Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1" Padding="10" Margin="0,5,0,15">
                            <StackPanel>
                                <CheckBox Content="{x:Static p:Resources.Str_ForceIntoFootnotes}" IsChecked="{Binding EditBlockIsFootnote}" FontWeight="Bold" Margin="0,0,0,10" />
                                <TextBlock Text="{x:Static p:Resources.Str_FootnoteDescription}" FontSize="11" Foreground="#555" Margin="0,0,0,5" />
                                <TextBox Text="{Binding EditBlockDesc, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center" IsEnabled="{Binding EditBlockIsFootnote}" />
                            </StackPanel>
                        </Border>

                        <Button Content="{x:Static p:Resources.Str_ApplyOverrides}" Command="{Binding ApplyBlockEditCommand}" Height="35" Background="#28A745" Foreground="White" FontWeight="Bold" Margin="0,15,0,10" />
                        <Button Content="{x:Static p:Resources.Str_CancelRevert}" Command="{Binding CancelBlockEditCommand}" Height="30" Background="#E74C3C" Foreground="White" FontWeight="Bold" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1" Margin="0,15,0,0">
                    <Button Content="{x:Static p:Resources.Str_ResetManualEdits}" Command="{Binding ResetOverridesCommand}" Height="28" Background="#6C757D" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,10" ToolTip="Clear all manual color, text, and layout overrides you made." />
                    <Button Content="{x:Static p:Resources.Str_GeneratePreview}" Command="{Binding GeneratePreviewCommand}" Height="35" Background="#0056B3" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" />
                    <Button Content="{x:Static p:Resources.Str_PrintA4Landscape}" Command="{Binding PrintCommand}" Height="35" Background="#2ECC71" Foreground="White" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: A4 PREVIEW WITH ZOOM -->
        <Grid Grid.Column="1" Background="#E0E0E0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}" />
                    </Grid.LayoutTransform>

                    <Border x:Name="PrintArea" Grid.IsSharedSizeScope="True" Width="1123" Height="794" Background="White" Padding="30">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- LEFT: TITLE & MAIN LEGEND -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ReportConfig.ReportTitle}" FontSize="24" FontWeight="Bold" Foreground="#333" />
                                    <TextBlock Text="{Binding ReportConfig.DateRangeText}" FontSize="14" Foreground="#666" Margin="0,2,0,10" />

                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,15,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Row 0 -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,12">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.RunningColor, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendRunning}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,12">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.BreakColor, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendBreak}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,15,12">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.ColorMa00Genel, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendMa00Genel}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" Margin="0,0,15,12">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.ColorMa00Cay, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendMa00Cay}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.ColorMa00Yemek, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendMa00Yemek}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>

                                            <!-- Row 1 -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.ColorMa00Other, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendMa00Other}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.ErrorColor, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendError}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,0,15,0">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.ErrorColor2, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendError2}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal" Margin="0,0,15,0">
                                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding ReportConfig.FacilityStopColor, Converter={StaticResource StringToBrush}}" BorderBrush="#D1D5DB" BorderThickness="1" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding ReportConfig.LegendFacilityStop}" FontSize="12" Foreground="#374151" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- RIGHT: MACHINE LEGEND & NEW MONTH SUMMARY BOX -->
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Top">

                                    <Border Visibility="{Binding ReportConfig.ShowMachineLegend, Converter={StaticResource BoolToVis}}" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Background="#F9FAFB" Padding="12,8" Margin="0,0,0,15">
                                        <ItemsControl ItemsSource="{Binding ReportConfig.LegendItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" MaxWidth="500" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="6,3">
                                                        <TextBlock Text="{Binding Code}" FontSize="10" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,5,0" />
                                                        <TextBlock Text="{Binding Name}" FontSize="10" Foreground="#4B5563" Margin="0,0,10,0" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- FIXED MONTH SUMMARY BOX (Matches Main Legend Design perfectly and uses new text) -->
                                    <Border Visibility="{Binding ReportConfig.ShowMonthSummary, Converter={StaticResource BoolToVis}}" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Background="#F9FAFB" Padding="15,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ReportConfig.MonthlySummary.Title}" FontSize="13" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="20" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Row 1 -->
                                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Günlük ortalama çalışma:" FontSize="11" Foreground="#4B5563" />
                                                    <TextBlock Text="{Binding ReportConfig.MonthlySummary.AvgDailyWorkStr}" FontSize="11" FontWeight="Bold" Foreground="#1F2937" Margin="5,0,0,0" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="Mesaisiz vardiya sayısı:" FontSize="11" Foreground="#4B5563" />
                                                    <TextBlock Text="{Binding ReportConfig.MonthlySummary.NoOvertimeShifts}" FontSize="11" FontWeight="Bold" Foreground="#1F2937" Margin="5,0,0,0" />
                                                </StackPanel>

                                                <!-- Row 2 -->
                                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="Günlük ortalama duruş:" FontSize="11" Foreground="#4B5563" />
                                                    <TextBlock Text="{Binding ReportConfig.MonthlySummary.AvgDailyStopStr}" FontSize="11" FontWeight="Bold" Foreground="#1F2937" Margin="5,0,0,0" />
                                                </StackPanel>

                                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                                                    <TextBlock Text="Tesisin çalışmadığı vardiya sayısı:" FontSize="11" Foreground="#4B5563" />
                                                    <TextBlock Text="{Binding ReportConfig.MonthlySummary.NotWorkedShifts}" FontSize="11" FontWeight="Bold" Foreground="#1F2937" Margin="5,0,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Background="#F3F4F6" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Extra1Col" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Extra2Col" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding ReportConfig.HeaderDate}" FontWeight="Bold" Foreground="#374151" FontSize="11" Padding="5" />
                                <TextBlock Grid.Column="1" Text="{Binding ReportConfig.HeaderShift}" FontWeight="Bold" Foreground="#374151" FontSize="11" Padding="5" HorizontalAlignment="Center" />

                                <Border Grid.Column="2" Width="75" Margin="0,0,15,0" Visibility="{Binding ReportConfig.ShowExtra1, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ReportConfig.ExtraTitle1}" FontWeight="Bold" Foreground="#374151" FontSize="11" Padding="5" TextAlignment="Right" />
                                </Border>
                                <Border Grid.Column="3" Width="75" Margin="0,0,15,0" Visibility="{Binding ReportConfig.ShowExtra2, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding ReportConfig.ExtraTitle2}" FontWeight="Bold" Foreground="#374151" FontSize="11" Padding="5" TextAlignment="Right" />
                                </Border>

                                <Canvas Grid.Column="4" Width="{Binding ReportConfig.TimelineWidth}" Height="20" Margin="15,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReportConfig.AxisTicks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding TopLabel}" FontSize="9" Foreground="#6B7280" FontWeight="SemiBold" Width="40" TextAlignment="Center" Margin="0,5,0,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding TextPixelLeft}" />
                                                <Setter Property="Canvas.Top" Value="0" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>

                            <!-- TIMELINE CONTENT -->
                            <Grid Grid.Row="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Extra1Col" />
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Extra2Col" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="2" Width="75" Margin="0,0,15,0" Visibility="{Binding ReportConfig.ShowExtra1, Converter={StaticResource BoolToVis}}" />
                                    <Border Grid.Column="3" Width="75" Margin="0,0,15,0" Visibility="{Binding ReportConfig.ShowExtra2, Converter={StaticResource BoolToVis}}" />

                                    <Canvas Grid.Column="4" Width="{Binding ReportConfig.TimelineWidth}" Margin="15,0,0,0" ClipToBounds="False">
                                        <ItemsControl ItemsSource="{Binding ReportConfig.AxisTicks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Line X1="0" Y1="0" X2="0" Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}" Stroke="#20000000" StrokeThickness="1" StrokeDashArray="4 2" IsHitTestVisible="False" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding PixelLeft}" />
                                                    <Setter Property="Canvas.Top" Value="0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                        </ItemsControl>
                                    </Canvas>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding ReportRows}" ClipToBounds="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0" ClipToBounds="False">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFFFFF" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAlternateBackground}" Value="True">
                                                                <Setter Property="Background" Value="#F9FAFB" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid ClipToBounds="False">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50" />
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Extra1Col" />
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Extra2Col" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayDate}" FontSize="{Binding DataContext.ReportConfig.TextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#374151" Padding="5,0" VerticalAlignment="Center" Visibility="{Binding ShowDate, Converter={StaticResource BoolToVis}}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayShift}" FontSize="{Binding DataContext.ReportConfig.SymbolFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#374151" Padding="5,0" HorizontalAlignment="Center" VerticalAlignment="Center" />

                                                    <Border Grid.Column="2" Width="75" Margin="0,0,15,0" Visibility="{Binding DataContext.ReportConfig.ShowExtra1, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding ExtraValue1}" FontSize="{Binding DataContext.ReportConfig.TextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#374151" Padding="5,0" TextAlignment="Right" VerticalAlignment="Center" />
                                                    </Border>
                                                    <Border Grid.Column="3" Width="75" Margin="0,0,15,0" Visibility="{Binding DataContext.ReportConfig.ShowExtra2, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding ExtraValue2}" FontSize="{Binding DataContext.ReportConfig.TextFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#374151" Padding="5,0" TextAlignment="Right" VerticalAlignment="Center" />
                                                    </Border>

                                                    <Canvas Grid.Column="4" Width="{Binding DataContext.ReportConfig.TimelineWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding DataContext.ReportConfig.RowHeight, RelativeSource={RelativeSource AncestorType=Window}}" Margin="15,2,0,2" HorizontalAlignment="Left" ClipToBounds="False">

                                                        <!-- LAYER 1: GEOMETRIC BLOCKS -->
                                                        <ItemsControl ItemsSource="{Binding Blocks}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <Canvas />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="{Binding VisualPixelWidth}" Height="{Binding PixelHeight}" Background="{Binding ColorHex, Converter={StaticResource StringToBrush}}"
                                                                            CornerRadius="{Binding CornerRadius}"
                                                                            BorderThickness="{Binding BlockBorder}" BorderBrush="#AA000000" Cursor="Hand">
                                                                        <Border.ToolTip>
                                                                            <ToolTip Background="#FFFFFF" BorderBrush="#D1D5DB">
                                                                                <TextBlock>
                                                                                    <Run Text="{Binding DisplayStartTime}" FontWeight="Bold" Foreground="#1F2937" />
                                                                                    <Run Text=" - " FontWeight="Bold" Foreground="#1F2937" />
                                                                                    <Run Text="{Binding DisplayEndTime}" FontWeight="Bold" Foreground="#1F2937" />
                                                                                    <LineBreak />
                                                                                    <Run Text="{Binding OriginalDescription}" Foreground="#4B5563" />
                                                                                </TextBlock>
                                                                            </ToolTip>
                                                                        </Border.ToolTip>
                                                                        <Border.InputBindings>
                                                                            <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.SelectBlockCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                                        </Border.InputBindings>
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                        <Setter Property="BorderThickness" Value="2" />
                                                                                        <Setter Property="BorderBrush" Value="#FFD700" />
                                                                                        <Setter Property="Panel.ZIndex" Value="99" />
                                                                                        <Setter Property="Effect">
                                                                                            <Setter.Value>
                                                                                                <DropShadowEffect Color="#FFD700" BlurRadius="6" ShadowDepth="0" Opacity="1.0" />
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                            <ItemsControl.ItemContainerStyle>
                                                                <Style TargetType="ContentPresenter">
                                                                    <Setter Property="Canvas.Left" Value="{Binding VisualPixelLeft}" />
                                                                    <Setter Property="Canvas.Top" Value="{Binding TopOffset}" />
                                                                    <Setter Property="Panel.ZIndex" Value="{Binding PanelZIndex}" />
                                                                </Style>
                                                            </ItemsControl.ItemContainerStyle>
                                                        </ItemsControl>

                                                        <!-- LAYER 2: TEXT LABELS -->
                                                        <ItemsControl ItemsSource="{Binding Blocks}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <Canvas ClipToBounds="False" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Width="{Binding PixelWidth}" Height="{Binding PixelHeight}" ClipToBounds="False" Margin="{Binding LabelMargin}">
                                                                        <TextBlock Text="{Binding Label}"
                                                                                   IsHitTestVisible="False"
                                                                                   Foreground="Black"
                                                                                   Opacity="0.75"
                                                                                   FontWeight="Bold"
                                                                                   FontSize="{Binding BlockFontSize}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="{Binding TextVerticalAlignment}"
                                                                                   Margin="1,1,-1,-1"
                                                                                   Padding="0,1,0,1"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="None"
                                                                                   ClipToBounds="False">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding DataContext.ReportConfig.ShowMajorErrorLabels, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                                                                <Condition Binding="{Binding Label, Converter={StaticResource IsNullOrEmptyConverter}}" Value="False" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>

                                                                        <TextBlock Text="{Binding Label}"
                                                                                   IsHitTestVisible="False"
                                                                                   Foreground="{Binding DataContext.ReportConfig.InnerLabelColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToBrush}}"
                                                                                   FontWeight="Bold"
                                                                                   FontSize="{Binding BlockFontSize}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="{Binding TextVerticalAlignment}"
                                                                                   Padding="0,1,0,1"
                                                                                   TextWrapping="NoWrap"
                                                                                   TextTrimming="None"
                                                                                   ClipToBounds="False">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <MultiDataTrigger>
                                                                                            <MultiDataTrigger.Conditions>
                                                                                                <Condition Binding="{Binding DataContext.ReportConfig.ShowMajorErrorLabels, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                                                                <Condition Binding="{Binding Label, Converter={StaticResource IsNullOrEmptyConverter}}" Value="False" />
                                                                                            </MultiDataTrigger.Conditions>
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </MultiDataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                            <ItemsControl.ItemContainerStyle>
                                                                <Style TargetType="ContentPresenter">
                                                                    <Setter Property="Canvas.Left" Value="{Binding PixelLeft}" />
                                                                    <Setter Property="Canvas.Top" Value="{Binding TopOffset}" />
                                                                    <Setter Property="Panel.ZIndex" Value="{Binding PanelZIndex}" />
                                                                </Style>
                                                            </ItemsControl.ItemContainerStyle>
                                                        </ItemsControl>
                                                    </Canvas>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Grid Grid.Row="3" Background="#F3F4F6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Extra1Col" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Extra2Col" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="2" Width="75" Margin="0,0,15,0" Visibility="{Binding ReportConfig.ShowExtra1, Converter={StaticResource BoolToVis}}" />
                                <Border Grid.Column="3" Width="75" Margin="0,0,15,0" Visibility="{Binding ReportConfig.ShowExtra2, Converter={StaticResource BoolToVis}}" />

                                <Canvas Grid.Column="4" Width="{Binding ReportConfig.TimelineWidth}" Height="20" Margin="15,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReportConfig.AxisTicks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BottomLabel}" FontSize="9" Foreground="#6B7280" FontWeight="SemiBold" Width="40" TextAlignment="Center" Margin="0,2,0,0" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding TextPixelLeft}" />
                                                <Setter Property="Canvas.Top" Value="0" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Canvas>
                            </Grid>

                            <Grid Grid.Row="4" Margin="0,15,0,0">
                                <ItemsControl ItemsSource="{Binding ReportConfig.Footnotes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Top" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFFFFF" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,0,8,8">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="2" Opacity="0.05" ShadowDepth="1" />
                                                </Border.Effect>
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="{Binding DataContext.ReportConfig.FootnoteFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                           Foreground="#374151"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Text}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>

            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="#AA000000" CornerRadius="5" Padding="10,5" Margin="20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔍 Zoom:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0" />
                    <Slider Minimum="0.5" Maximum="3.0" Value="{Binding ZoomScale}" Width="120" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="0.1" ToolTip="Adjust Zoom Level" />
                    <TextBlock Text="{Binding ZoomScale, StringFormat={}{0:P0}}" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Width="40" TextAlignment="Right" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
