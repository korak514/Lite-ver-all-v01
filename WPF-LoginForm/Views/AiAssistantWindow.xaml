<Window x:Class="WPF_LoginForm.Views.AiAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WPF_LoginForm.Converters"
        Title="AI Bridge" Height="750" Width="880"
        WindowStartupLocation="CenterOwner"
        Background="#09092B"
        MinWidth="600" MinHeight="400">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanConverter x:Key="BooleanInverter" />
        <converters:BooleanInverterConverter x:Key="BoolInverter" />

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="AI Bridge" Foreground="#1ABC9C" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Grid Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis" />
                <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="3" Margin="0,2,0,0"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                             Foreground="#1ABC9C" Background="#30FFFFFF" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" x:Name="MessageScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" BorderBrush="#30FFFFFF" BorderThickness="0.5" MaxWidth="780">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#15FFFFFF" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="User"><Setter Property="Background" Value="#251ABC9C" /></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="System"><Setter Property="Background" Value="#0A3498DB" /><Setter Property="BorderBrush" Value="#303498DB" /></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="ToolCall"><Setter Property="Background" Value="#0AF39C12" /><Setter Property="BorderBrush" Value="#30F39C12" /></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="ToolResult"><Setter Property="BorderBrush" Value="#301ABC9C" /></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="6" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" FontSize="11" FontWeight="Bold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Assistant" /><Setter Property="Foreground" Value="#1ABC9C" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Type}" Value="User"><Setter Property="Text" Value="You" /><Setter Property="Foreground" Value="#3498DB" /></DataTrigger>
                                                                                <DataTrigger Binding="{Binding Type}" Value="System"><Setter Property="Text" Value="System" /><Setter Property="Foreground" Value="#3498DB" /></DataTrigger>
                                                                                <DataTrigger Binding="{Binding Type}" Value="ToolCall"><Setter Property="Text" Value="Tool Call" /><Setter Property="Foreground" Value="#F39C12" /></DataTrigger>
                                                                                <DataTrigger Binding="{Binding Type}" Value="ToolResult"><Setter Property="Text" Value="Result" /><Setter Property="Foreground" Value="#1ABC9C" /></DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Grid.Column="1" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Type}" Value="ToolCall">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                    <Setter Property="Text" Value="{Binding ToolName}" />
                                                                                    <Setter Property="Foreground" Value="#F39C12" />
                                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <Button Grid.Column="2" Content="📋" Command="{Binding CopyMessageCommand}" Background="Transparent" Foreground="#666666" FontSize="11" Width="22" Height="22" Padding="0" BorderThickness="0" Cursor="Hand" ToolTip="Copy message" />
                                                                <TextBlock Grid.Column="4" Text="{Binding TimestampStr}" Foreground="Gray" FontSize="10" VerticalAlignment="Center" />
                                                            </Grid>

                                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                       Visibility="{Binding IsToolCall, Converter={StaticResource BoolInverter}}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="WhiteSmoke" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type}" Value="User"><Setter Property="Foreground" Value="White" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding Type}" Value="System"><Setter Property="Foreground" Value="#88BBBBBB" /><Setter Property="FontSize" Value="11" /><Setter Property="FontFamily" Value="Consolas" /></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <Border CornerRadius="4" Background="#1AF39C12" Padding="8" Margin="0,4,0,4"
                                                                    Visibility="{Binding IsToolCall, Converter={StaticResource BoolToVis}}">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                        <TextBlock Text="Tool:" Foreground="#F39C12" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding ToolName}" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" />
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding ToolParamsDisplay}" Foreground="#CCFFFFFF" FontSize="11" FontFamily="Consolas" Margin="0,4,0,0" TextWrapping="Wrap" />
                                                                    <TextBlock Text="{Binding ExecutionStatus}" Foreground="{Binding StatusColor}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0" />
                                                                </StackPanel>
                                                            </Border>

                                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                                        Visibility="{Binding ShowActions, Converter={StaticResource BoolToVis}}">
                                                                <Button Content="Execute" Command="{Binding ExecuteToolCommand}" Background="#1ABC9C" Width="90" Height="28" Style="{StaticResource ActionButton}" FontSize="12" Margin="0,0,8,0" />
                                                                <Button Content="Cancel" Command="{Binding CancelToolCommand}" Background="#D14545" Width="90" Height="28" Style="{StaticResource ActionButton}" FontSize="12" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="1" Background="#15000000" CornerRadius="6" Padding="8" Margin="0,5,0,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBox Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="#1AFFFFFF" Foreground="WhiteSmoke" BorderThickness="1" BorderBrush="#30FFFFFF" Padding="8,6" FontSize="13" AcceptsReturn="False" VerticalContentAlignment="Center" x:Name="InputTextBox" KeyDown="InputTextBox_KeyDown" />
                    <Button Grid.Column="1" Content="Send" Command="{Binding SendCommand}" Background="#1ABC9C" Width="80" Height="30" Style="{StaticResource ActionButton}" FontSize="13" Margin="8,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#0AFFFFFF" CornerRadius="4" Padding="8,4" Margin="0,5,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Messages.Count, StringFormat='Messages: {0}'}" Foreground="Gray" FontSize="11" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>