<!-- Views/ErrorDrillDownWindow.xaml -->
<Window x:Class="WPF_LoginForm.Views.ErrorDrillDownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:p="clr-namespace:WPF_LoginForm.Properties"
        xmlns:local="clr-namespace:WPF_LoginForm.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="780" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.Background}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" GlassFrameThickness="0" CornerRadius="0" ResizeBorderThickness="5" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="TitleBarButtonStyle" TargetType="Button">
                <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Width" Value="45" />
                <Setter Property="Height" Value="30" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#44FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FilterChipStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>

            <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{DynamicResource Theme.Combo.Background}" />
                <Setter Property="Foreground" Value="{DynamicResource Theme.Combo.Foreground}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="Gray" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <Grid>
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="5,0,0,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static p:Resources.Str_SearchDots}" Foreground="Gray" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed" x:Name="PlaceholderText" />
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                                    <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FooterCloseButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="BorderBrush" Value="{DynamicResource Theme.Text.Primary}" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="35,10" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Theme.Text.Primary}" />
                        <Setter Property="Foreground" Value="{DynamicResource Theme.Background}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ROW 0: TITLE BAR -->
        <Border Grid.Row="0" Background="{DynamicResource Theme.TitleBar}">
            <Grid>
                <TextBlock Text="{Binding WindowTitle}" Foreground="White" VerticalAlignment="Center" Margin="15,0" FontSize="11" FontWeight="SemiBold" Opacity="0.8" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="ThemeToggle_Click" Background="Transparent" BorderThickness="0" Width="40" WindowChrome.IsHitTestVisibleInChrome="True">
                        <fa:IconImage Icon="Adjust" Foreground="White" Width="14" Height="14" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}" Click="MinimizeButton_Click">
                        <TextBlock Text="—" VerticalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource TitleBarButtonStyle}" Click="CloseButton_Click">
                        <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: HEADER & STATS -->
        <Border Grid.Row="1" Background="{DynamicResource Theme.Panel}" Padding="25,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding WindowTitle}" FontSize="24" FontWeight="ExtraBold" Foreground="{DynamicResource Theme.Text.Primary}" />
                    <TextBlock Text="{x:Static p:Resources.Drill_Title}" FontSize="13" Foreground="{DynamicResource Theme.Text.Secondary}" Margin="0,5,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Background="{DynamicResource Theme.Grid.Header}" CornerRadius="4" Padding="20,10" Margin="0,0,15,0">
                        <StackPanel>
                            <TextBlock Text="{x:Static p:Resources.Drill_Count}" Foreground="{DynamicResource Theme.Text.Secondary}" FontSize="11" FontWeight="Bold" />
                            <TextBlock Text="{Binding RecordCount}" Foreground="{DynamicResource Theme.Text.Primary}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Background="#C0392B" CornerRadius="4" Padding="20,10">
                        <StackPanel>
                            <TextBlock Text="{x:Static p:Resources.Drill_TotalDuration}" Foreground="#FADBD8" FontSize="11" FontWeight="Bold" />
                            <TextBlock Text="{Binding TotalDurationText}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 2: ACTIVE FILTERS (Chips) -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding ActiveFilters}" Margin="25,10,25,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource FilterChipStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Label}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" FontSize="13" />
                            <Button Command="{Binding DataContext.RemoveFilterChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" Margin="10,0,0,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="✕" Foreground="White" FontSize="12" />
                            </Button>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ROW 3: DUAL LIST SELECTOR (Expandable) -->
        <Grid Grid.Row="3" Margin="25,10,25,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Machine Filter -->
                <Border Grid.Column="0" Background="{DynamicResource Theme.Panel}" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Str_Machines}" Foreground="{DynamicResource Theme.Text.Primary}" FontWeight="Bold" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1" Text="{Binding MachineSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,8" />

                        <!-- Dynamic Height ScrollViewer -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Height" Value="60" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFiltersExpanded}" Value="True">
                                            <Setter Property="Height" Value="170" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <ItemsControl ItemsSource="{Binding FilteredMachineList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="0,4" Foreground="{DynamicResource Theme.Text.Primary}" FontSize="13" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- RIGHT: Reason Filter -->
                <Border Grid.Column="2" Background="{DynamicResource Theme.Panel}" CornerRadius="6" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{x:Static p:Resources.Str_ErrorCategories}" Foreground="{DynamicResource Theme.Text.Primary}" FontWeight="Bold" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1" Text="{Binding ReasonSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource SearchTextBoxStyle}" Margin="0,0,0,8" />

                        <!-- Dynamic Height ScrollViewer -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Height" Value="60" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFiltersExpanded}" Value="True">
                                            <Setter Property="Height" Value="170" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <ItemsControl ItemsSource="{Binding FilteredReasonList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="0,4" Foreground="{DynamicResource Theme.Text.Primary}" FontSize="13" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Expand/Collapse Toggle Button -->
            <ToggleButton Grid.Row="1" HorizontalAlignment="Center" Margin="0,5,0,0"
                          IsChecked="{Binding IsFiltersExpanded, Mode=TwoWay}"
                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Theme.Accent}" Cursor="Hand" FontWeight="Bold">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Content" Value="{x:Static p:Resources.Str_ExpandFilters}" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="{x:Static p:Resources.Str_CollapseFilters}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
        </Grid>

        <!-- ROW 4: DATA GRID -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding DisplayedItems}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource Theme.Grid.Lines}"
                  VerticalGridLinesBrush="Transparent"
                  RowHeight="40"
                  FontSize="14"
                  Background="Transparent"
                  BorderThickness="0"
                  Margin="25,0,25,10">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource Theme.Grid.Header}" />
                    <Setter Property="Foreground" Value="{DynamicResource Theme.Accent}" />
                    <Setter Property="Padding" Value="12,12" />
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{DynamicResource Theme.Grid.Row}" />
                    <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Theme.Grid.Lines}" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Theme.Grid.Header}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static p:Resources.Col_Date}" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="110" />
                <DataGridTextColumn Header="{x:Static p:Resources.Col_Machine}" Binding="{Binding MachineDisplay}" Width="110" FontWeight="Bold" />
                <DataGridTextColumn Header="{x:Static p:Resources.Col_Timeline}" Binding="{Binding TimeRange}" Width="150" />
                <DataGridTextColumn Header="{x:Static p:Resources.Col_Duration}" Binding="{Binding DisplayDuration}" SortMemberPath="DurationMinutes" Width="100" FontWeight="Bold" />

                <!-- MODIFIED: Description column now features a Hover-Activated Arrow button -->
                <DataGridTemplateColumn Header="{x:Static p:Resources.Col_Description}" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ErrorDescription}" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0" />
                                <Button Grid.Column="1" x:Name="NavButton"
                                        Command="{Binding DataContext.NavigateToDataCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Visibility="Hidden" Padding="15,0" ToolTip="{x:Static p:Resources.Tip_FindInDataReport}">
                                    <fa:IconImage Icon="ArrowRight" Height="14" Foreground="{DynamicResource Theme.Accent}" />
                                </Button>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                    <Setter TargetName="NavButton" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ROW 5: FOOTER -->
        <Border Grid.Row="5" Background="{DynamicResource Theme.Footer}" Padding="20">
            <Grid>
                <Button Content="{x:Static p:Resources.Cancel}" Style="{StaticResource FooterCloseButtonStyle}" Click="CloseButton_Click" HorizontalAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</Window>